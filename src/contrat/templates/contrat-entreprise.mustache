<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <title>Contrat d’Abonnement</title>
  <style>
    @page { margin: 22mm 18mm; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 12px;
      color: #111;
      line-height: 1.45;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 2px solid #111;
    }

    .brand h1 {
      margin: 0;
      font-size: 20px;
      letter-spacing: .3px;
    }

    .brand .sub {
      margin-top: 4px;
      font-size: 11px;
      color: #555;
    }

    .meta {
      text-align: right;
      font-size: 11px;
      color: #444;
    }

    .meta .ref {
      font-weight: 700;
      color: #111;
      margin-bottom: 6px;
    }

    .section {
      margin-top: 14px;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 8px;
    }

    .section-title {
      font-size: 13px;
      font-weight: 700;
      margin: 0 0 10px 0;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px 16px;
    }

    .field .label {
      font-size: 10.5px;
      color: #666;
      margin-bottom: 2px;
      text-transform: uppercase;
      letter-spacing: .2px;
    }

    .field .value {
      font-size: 12px;
      font-weight: 600;
      color: #111;
      word-break: break-word;
    }

    .conditions {
      margin-top: 10px;
      padding-left: 18px;
    }

    .conditions li {
      margin: 4px 0;
    }

    .signatures {
      margin-top: 12px;
      display: flex;
      justify-content: flex-start;
    }

    .sig-box {
      border: 1px dashed #888;
      border-radius: 8px;
      padding: 12px;
      min-height: 150px;
      width: 360px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .sig-title {
      font-weight: 700;
      font-size: 12px;
      margin-bottom: 8px;
    }

    .sig-image {
      margin-top: 8px;
      margin-bottom: 10px;
      display: flex;
      justify-content: flex-start;
      align-items: center;
      min-height: 70px;
    }

    .sig-image img {
      max-width: 240px;
      max-height: 80px;
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 4px;
      background: #fff;
    }

    .sig-empty {
      margin-top: 8px;
      min-height: 70px;
      display: flex;
      align-items: flex-end;
      color: #444;
    }

    .sig-line {
      border-top: 1px solid #222;
      padding-top: 6px;
      font-size: 11px;
      color: #555;
    }

    .footer {
      margin-top: 14px;
      font-size: 10px;
      color: #777;
      border-top: 1px solid #ddd;
      padding-top: 10px;
    }

    .muted {
      color: #666;
      font-weight: 400;
    }
  </style>
</head>
<body>

  <div class="header">
    <div class="brand">
      <h1>Contrat d’abonnement</h1>
      <div class="sub">Document généré automatiquement</div>
    </div>

    <div class="meta">
      <div class="ref">Réf: {{contratId}}</div>
      <div>Date de génération: {{dateGeneration}}</div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">1) Informations</div>

    <div class="grid">
      <div class="field">
        <div class="label">Entreprise</div>
        <div class="value">{{entrepriseNom}}</div>
      </div>

      <div class="field">
        <div class="label">Propriétaire (email)</div>
        <div class="value">{{proprietaireEmail}}</div>
      </div>

      <div class="field">
        <div class="label">Abonnement</div>
        <div class="value">{{abonnementNom}}</div>
      </div>

      <div class="field">
        <div class="label">Prix</div>
        <div class="value">{{prixFormate}} <span class="muted">/ {{dureeMois}} mois</span></div>
      </div>

      <div class="field">
        <div class="label">Date début</div>
        <div class="value">{{dateDebut}}</div>
      </div>

      <div class="field">
        <div class="label">Date fin</div>
        <div class="value">{{dateFin}}</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">2) Conditions</div>
    <ul class="conditions">
      <li>Paiement géré via Stripe.</li>
      <li>Renouvellement automatique selon les règles Stripe.</li>
      <li>Activation du service après confirmation du paiement et signature du contrat.</li>
    </ul>
  </div>

  <div class="section">
    <div class="section-title">3) Signature</div>

    <div class="signatures">
      <div class="sig-box">
        <div>
          <div class="sig-title">Entreprise</div>

          {{#signatureImage}}
            <div class="sig-image">
              <img src="{{signatureImage}}" alt="Signature entreprise" />
            </div>
          {{/signatureImage}}

          {{^signatureImage}}
            <div class="sig-empty">__________________________</div>
          {{/signatureImage}}
        </div>

        <div class="sig-line">Nom / Signature / Cachet</div>
      </div>
    </div>
  </div>

  <div class="footer">
    <div>Ce document est généré automatiquement et peut être stocké dans votre espace.</div>
    <div class="muted">Référence contrat: {{contratId}}</div>
  </div>

</body>
</html>